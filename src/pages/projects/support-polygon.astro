
---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Support-Polygon Gait Planner — Srikrishnan Sridhar">
  <a href="/" class="text-sm text-gray-600 hover:text-gray-900">← back</a>
  <h1 class="mt-4 text-3xl font-bold">Support-Polygon Quadruped Gait Planner</h1>

  <section class="mt-8">
    <h2 class="text-xl font-semibold">Problem</h2>
    <p class="mt-2 text-gray-700 leading-relaxed">[Problem description]</p>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold">My Role</h2>
    <p class="mt-2 text-gray-700 leading-relaxed">[Your role on the project]</p>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold">Method</h2>
    <p class="mt-2 text-gray-700 leading-relaxed">[Methods]</p>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold">Interactive Demo</h2>
    <div class="mt-2 p-12 border-2 border-dashed border-gray-300 rounded-lg text-center text-gray-400">
      [demo goes here]
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold">Results</h2>
    <p class="mt-2 text-gray-700 leading-relaxed">[Results]</p>
