<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  document.querySelectorAll('.project-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-modal-id');
      const modal = document.getElementById(`modal-${id}`);
      if (modal instanceof HTMLDialogElement) {
        modal.showModal();
        if (id === 'support-polygon') requestAnimationFrame(runSupportPolygonGenerator);
      }
    });
  });
  document.querySelectorAll('.close-modal').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const dialog = (e.target as HTMLElement).closest('dialog');
      if (dialog instanceof HTMLDialogElement) dialog.close();
    });
  });
  document.querySelectorAll('dialog').forEach((dialog) => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog && dialog instanceof HTMLDialogElement) dialog.close();
    });
  });

  const waveriderForm = document.getElementById('waverider-form');
  const waveriderStatus = document.getElementById('waverider-status');
  const waveriderResults = document.getElementById('waverider-results');
  const waveriderPlotly = document.getElementById('waverider-plotly');
  const fallbackFigure = document.getElementById('fallback-figure');
  const fallbackPlot = document.getElementById('fallback-plot');
  const waveriderSummary = document.getElementById('waverider-summary');
  const waveriderLog = document.getElementById('waverider-log');
  const plotWaverider = document.getElementById('plot-waverider');
  const supportPolygonPlot = document.getElementById('support-polygon-plot');
  const supportPolygonForm = document.getElementById('support-polygon-form');
  const runSupportPolygon = document.getElementById('run-support-polygon');
  const supportPolygonStatus = document.getElementById('support-polygon-status');
  const supportPolygonSummary = document.getElementById('support-polygon-summary');
  const runInletMatlab = document.getElementById('run-inlet-matlab');
  const inletForm = document.getElementById('inlet-form');
  const inletMatlabStatus = document.getElementById('inlet-matlab-status');
  const inletMatlabFigure = document.getElementById('inlet-matlab-figure');
  const inletMatlabPlot = document.getElementById('inlet-matlab-plot');
  const fctEquation = document.getElementById('fct-equation');
  const iccEquation = document.getElementById('icc-equation');
  const fctPreviewPath = document.getElementById('fct-preview-path');
  const iccPreviewPath = document.getElementById('icc-preview-path');

  let threeRenderer: THREE.WebGLRenderer | null = null;
  let threeScene: THREE.Scene | null = null;
  let threeCamera: THREE.PerspectiveCamera | null = null;
  let threeControls: OrbitControls | null = null;
  let threeAnimation = 0;
  let supportRenderer: THREE.WebGLRenderer | null = null;
  let supportScene: THREE.Scene | null = null;
  let supportCamera: THREE.PerspectiveCamera | null = null;
  let supportControls: OrbitControls | null = null;
  let supportAnimation = 0;
  let supportPlaybackGroup: THREE.Group | null = null;

  function parseNumberList(value: FormDataEntryValue | null) {
    return String(value || '')
      .split(',')
      .map((part) => Number(part.trim()))
      .filter((value) => Number.isFinite(value));
  }

  function collectWaveriderPayload() {
    if (!(waveriderForm instanceof HTMLFormElement)) return {};
    const formData = new FormData(waveriderForm);
    return {
      mach: Number(formData.get('mach')),
      gamma: Number(formData.get('gamma')),
      beta: Number(formData.get('beta')),
      seed_num: Number(formData.get('seed_num')),
      nghost: Number(formData.get('nghost')),
      span: Number(formData.get('span')),
      nsamples: Number(formData.get('nsamples')),
      fct_type: String(formData.get('fct_type') || 'Cosine'),
      fct_abcdn: parseNumberList(formData.get('fct_abcdn')),
      icc_type: String(formData.get('icc_type') || 'Cosine'),
      icc_abcdn: parseNumberList(formData.get('icc_abcdn')),
    };
  }

  function curveValue(type: string, abcdn: number[], y: number, span: number) {
    const [a = 0, b = 0, c = 0, d = 0, n = 1] = abcdn;
    if (type === 'Power') return a * Math.pow(b * y - c, n) + d;
    if (type === 'Absolute Value') return a * Math.pow(Math.abs(b * y - c), n) + d;
    if (type === 'Circle') return a * Math.sqrt(Math.max(0, (0.5 * span) ** 2 - y ** 2)) + d;
    return a * Math.pow(Math.cos(b * Math.PI * y - c), n) + d;
  }

  function equationText(type: string, values: number[]) {
    const [a = 0, b = 0, c = 0, d = 0, n = 1] = values;
    if (type === 'Power') return `z = ${a}(${b}y - ${c})^${n} + ${d}`;
    if (type === 'Absolute Value') return `z = ${a}|${b}y - ${c}|^${n} + ${d}`;
    if (type === 'Circle') return `z = ${a}sqrt((span/2)^2 - y^2) + ${d}`;
    return `z = ${a}cos(${b}πy - ${c})^${n} + ${d}`;
  }

  function pathFromPoints(points: { x: number; y: number }[]) {
    return points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`).join(' ');
  }

  function updateCurvePreview() {
    if (!(waveriderForm instanceof HTMLFormElement)) return;
    const formData = new FormData(waveriderForm);
    const span = Number(formData.get('span')) || 0.5;
    const fctType = String(formData.get('fct_type') || 'Cosine');
    const iccType = String(formData.get('icc_type') || 'Cosine');
    const fctVals = parseNumberList(formData.get('fct_abcdn'));
    const iccVals = parseNumberList(formData.get('icc_abcdn'));
    const raw = Array.from({ length: 120 }, (_, i) => {
      const y = -0.5 * span + (span * i) / 119;
      return {
        y,
        fct: curveValue(fctType, fctVals, y, span),
        icc: curveValue(iccType, iccVals, y, span),
      };
    }).filter((point) => Number.isFinite(point.fct) && Number.isFinite(point.icc));

    if (fctEquation) fctEquation.textContent = equationText(fctType, fctVals);
    if (iccEquation) iccEquation.textContent = equationText(iccType, iccVals);
    if (!raw.length || !(fctPreviewPath instanceof SVGPathElement) || !(iccPreviewPath instanceof SVGPathElement)) return;

    const yMin = Math.min(...raw.map((p) => p.y));
    const yMax = Math.max(...raw.map((p) => p.y));
    const zMin = Math.min(...raw.flatMap((p) => [p.fct, p.icc]));
    const zMax = Math.max(...raw.flatMap((p) => [p.fct, p.icc]));
    const project = (y: number, z: number) => ({
      x: 24 + ((y - yMin) / Math.max(1e-9, yMax - yMin)) * 312,
      y: 196 - ((z - zMin) / Math.max(1e-9, zMax - zMin)) * 172,
    });

    fctPreviewPath.setAttribute('d', pathFromPoints(raw.map((p) => project(p.y, p.fct))));
    iccPreviewPath.setAttribute('d', pathFromPoints(raw.map((p) => project(p.y, p.icc))));
  }

  function clearThreePlot() {
    if (threeAnimation) cancelAnimationFrame(threeAnimation);
    threeAnimation = 0;
    if (threeControls) threeControls.dispose();
    if (threeRenderer) threeRenderer.dispose();
    threeRenderer = null;
    threeScene = null;
    threeCamera = null;
    threeControls = null;
    if (waveriderPlotly) waveriderPlotly.replaceChildren();
  }

  function lineObject(line: any, color: number, opacity = 1) {
    const points = (line.x || []).map((x: number, index: number) => new THREE.Vector3(x, line.y[index], line.z[index]));
    const geometry = new THREE.BufferGeometry().setFromPoints(points);
    const material = new THREE.LineBasicMaterial({
      color,
      transparent: opacity < 1,
      opacity,
    });
    return new THREE.Line(geometry, material);
  }

  function renderInteractiveGeometry(geometry: any) {
    if (!waveriderPlotly) return;
    clearThreePlot();

    const width = Math.max(320, waveriderPlotly.clientWidth);
    const height = Math.max(430, waveriderPlotly.clientHeight);
    threeScene = new THREE.Scene();
    threeScene.background = new THREE.Color(0xffffff);
    threeCamera = new THREE.PerspectiveCamera(45, width / height, 0.001, 1000);
    threeRenderer = new THREE.WebGLRenderer({ antialias: true });
    threeRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    threeRenderer.setSize(width, height);
    waveriderPlotly.appendChild(threeRenderer.domElement);

    const group = new THREE.Group();
    (geometry.bottom || []).forEach((line: any) => group.add(lineObject(line, 0xdc2626)));
    (geometry.top || []).forEach((line: any) => group.add(lineObject(line, 0x2563eb)));
    (geometry.shock || []).forEach((line: any) => group.add(lineObject(line, 0x16a34a, 0.38)));

    const leading = geometry.leadingEdge;
    if (leading?.x?.length) {
      const points = leading.x.map((x: number, index: number) => new THREE.Vector3(x, leading.y[index], leading.z[index]));
      const pointGeometry = new THREE.BufferGeometry().setFromPoints(points);
      const pointMaterial = new THREE.PointsMaterial({ color: 0x111827, size: 0.01, sizeAttenuation: true });
      group.add(new THREE.Points(pointGeometry, pointMaterial));
    }

    const box = new THREE.Box3().setFromObject(group);
    const center = new THREE.Vector3();
    const size = new THREE.Vector3();
    box.getCenter(center);
    box.getSize(size);
    group.position.sub(center);
    threeScene.add(group);

    const axes = new THREE.AxesHelper(Math.max(size.x, size.y, size.z) * 0.6 || 0.5);
    threeScene.add(axes);
    threeScene.add(new THREE.AmbientLight(0xffffff, 1));

    const radius = Math.max(size.x, size.y, size.z) || 1;
    threeCamera.position.set(radius * 1.35, -radius * 1.4, radius * 0.85);
    threeCamera.near = radius / 1000;
    threeCamera.far = radius * 1000;
    threeCamera.updateProjectionMatrix();

    threeControls = new OrbitControls(threeCamera, threeRenderer.domElement);
    threeControls.enableDamping = true;
    threeControls.target.set(0, 0, 0);

    const resizeObserver = new ResizeObserver(() => {
      if (!threeRenderer || !threeCamera || !waveriderPlotly) return;
      const nextWidth = Math.max(320, waveriderPlotly.clientWidth);
      const nextHeight = Math.max(430, waveriderPlotly.clientHeight);
      threeCamera.aspect = nextWidth / nextHeight;
      threeCamera.updateProjectionMatrix();
      threeRenderer.setSize(nextWidth, nextHeight);
    });
    resizeObserver.observe(waveriderPlotly);

    const animate = () => {
      if (!threeRenderer || !threeScene || !threeCamera) return;
      threeControls?.update();
      threeRenderer.render(threeScene, threeCamera);
      threeAnimation = requestAnimationFrame(animate);
    };
    animate();
  }

  function clearSupportPlot() {
    if (supportAnimation) cancelAnimationFrame(supportAnimation);
    supportAnimation = 0;
    supportControls?.dispose();
    supportRenderer?.dispose();
    supportRenderer = null;
    supportScene = null;
    supportCamera = null;
    supportControls = null;
    supportPlaybackGroup = null;
    supportPolygonPlot?.replaceChildren();
  }

  function polygonMesh(points: THREE.Vector3[], color: number, opacity: number) {
    const geometry = new THREE.BufferGeometry();
    const vertices = new Float32Array([
      ...points[0].toArray(), ...points[1].toArray(), ...points[2].toArray(),
      ...points[0].toArray(), ...points[2].toArray(), ...points[3].toArray(),
    ]);
    geometry.setAttribute('position', new THREE.BufferAttribute(vertices, 3));
    geometry.computeVertexNormals();
    const material = new THREE.MeshBasicMaterial({
      color,
      opacity,
      side: THREE.DoubleSide,
      transparent: opacity < 1,
    });
    return new THREE.Mesh(geometry, material);
  }

  function polygonOutline(points: THREE.Vector3[], color: number) {
    const geometry = new THREE.BufferGeometry().setFromPoints([...points, points[0]]);
    return new THREE.Line(geometry, new THREE.LineBasicMaterial({ color, linewidth: 1 }));
  }

  function vectorFromArray(value: number[]) {
    return new THREE.Vector3(value?.[0] || 0, value?.[1] || 0, value?.[2] || 0);
  }

  function addBodyAxes(group: THREE.Group, center: THREE.Vector3, axes: any, scale = 0.14) {
    const xAxis = vectorFromArray(axes?.x || [1, 0, 0]).normalize();
    const yAxis = vectorFromArray(axes?.y || [0, 1, 0]).normalize();
    const zAxis = vectorFromArray(axes?.z || [0, 0, 1]).normalize();
    group.add(new THREE.ArrowHelper(xAxis, center, scale, 0xdc2626, scale * 0.28, scale * 0.15));
    group.add(new THREE.ArrowHelper(yAxis, center, scale, 0x16a34a, scale * 0.28, scale * 0.15));
    group.add(new THREE.ArrowHelper(zAxis, center, scale, 0x2563eb, scale * 0.28, scale * 0.15));
  }

  function renderPlaybackFrame(step: any) {
    if (!supportPlaybackGroup) return;
    supportPlaybackGroup.clear();

    const corners = (step?.corners || []).map((point: number[]) => vectorFromArray(point));
    if (corners.length !== 4) return;

    supportPlaybackGroup.add(polygonMesh(corners, 0xf97316, 0.78));
    supportPlaybackGroup.add(polygonOutline(corners, 0x7c2d12));
    const center = vectorFromArray(step.center || [0, 0, 0]);
    addBodyAxes(supportPlaybackGroup, center, step.axes, 0.25);

    const footGeometry = new THREE.SphereGeometry(0.035, 18, 18);
    const colors = [0xdc2626, 0x16a34a, 0x2563eb, 0x9333ea];
    corners.forEach((corner, index) => {
      const foot = new THREE.Mesh(
        footGeometry,
        new THREE.MeshBasicMaterial({ color: colors[index % colors.length] }),
      );
      foot.position.copy(corner);
      supportPlaybackGroup?.add(foot);
    });
  }

  function renderSupportPolygonPlot(data: any) {
    if (!supportPolygonPlot) return;
    clearSupportPlot();

    const width = Math.max(320, supportPolygonPlot.clientWidth);
    const height = Math.max(430, supportPolygonPlot.clientHeight);
    supportScene = new THREE.Scene();
    supportScene.background = new THREE.Color(0xffffff);
    supportCamera = new THREE.PerspectiveCamera(42, width / height, 0.001, 1000);
    supportRenderer = new THREE.WebGLRenderer({ antialias: true });
    supportRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    supportRenderer.setSize(width, height);
    supportPolygonPlot.appendChild(supportRenderer.domElement);

    const group = new THREE.Group();
    const trajectory = (data.trajectory || []).map((point: number[]) => vectorFromArray(point));
    const trajectoryGeometry = new THREE.BufferGeometry().setFromPoints(trajectory);
    group.add(new THREE.Line(trajectoryGeometry, new THREE.LineBasicMaterial({ color: 0x111827, linewidth: 2 })));

    const frames = data.frames || [];
    const highlight = Math.floor(frames.length * 0.42);
    frames.forEach((frame: any, frameIndex: number) => {
      if (frameIndex % 2 !== 0) return;
      const corners = (frame.corners || []).map((point: number[]) => vectorFromArray(point));
      if (corners.length !== 4) return;
      const opacity = frameIndex === highlight || frameIndex === highlight - 1 ? 0.72 : 0.2;
      group.add(polygonMesh(corners, opacity > 0.5 ? 0x0891b2 : 0x67e8f9, opacity));
      group.add(polygonOutline(corners, 0x0f172a));
      if (frameIndex % 6 === 0 || opacity > 0.5) addBodyAxes(group, vectorFromArray(frame.center), frame.axes, opacity > 0.5 ? 0.22 : 0.13);
    });

    const pointsMaterial = new THREE.PointsMaterial({ color: 0x0f172a, size: 0.025, sizeAttenuation: true });
    group.add(new THREE.Points(trajectoryGeometry, pointsMaterial));
    supportPlaybackGroup = new THREE.Group();
    group.add(supportPlaybackGroup);

    const box = new THREE.Box3().setFromObject(group);
    const center = new THREE.Vector3();
    const size = new THREE.Vector3();
    box.getCenter(center);
    box.getSize(size);
    group.position.sub(center);
    supportScene.add(group);
    supportScene.add(new THREE.AmbientLight(0xffffff, 1));

    const radius = Math.max(size.x, size.y, size.z) || 1;
    supportCamera.position.set(radius * 1.35, -radius * 1.7, radius * 0.9);
    supportCamera.near = radius / 1000;
    supportCamera.far = radius * 1000;
    supportCamera.updateProjectionMatrix();

    supportControls = new OrbitControls(supportCamera, supportRenderer.domElement);
    supportControls.enableDamping = true;
    supportControls.target.set(0, 0, 0);
    const gait = data.gait || [];
    let lastPlaybackIndex = -1;
    const startTime = performance.now();
    if (gait.length) renderPlaybackFrame(gait[0]);

    const resizeObserver = new ResizeObserver(() => {
      if (!supportRenderer || !supportCamera || !supportPolygonPlot) return;
      const nextWidth = Math.max(320, supportPolygonPlot.clientWidth);
      const nextHeight = Math.max(430, supportPolygonPlot.clientHeight);
      supportCamera.aspect = nextWidth / nextHeight;
      supportCamera.updateProjectionMatrix();
      supportRenderer.setSize(nextWidth, nextHeight);
    });
    resizeObserver.observe(supportPolygonPlot);

    const animate = () => {
      if (!supportRenderer || !supportScene || !supportCamera) return;
      if (gait.length) {
        const elapsed = performance.now() - startTime;
        const playbackIndex = Math.min(gait.length - 1, Math.floor(elapsed / 160));
        if (playbackIndex !== lastPlaybackIndex) {
          renderPlaybackFrame(gait[playbackIndex]);
          lastPlaybackIndex = playbackIndex;
        }
      }
      supportControls?.update();
      supportRenderer.render(supportScene, supportCamera);
      supportAnimation = requestAnimationFrame(animate);
    };
    animate();
  }

  async function runSupportPolygonGenerator() {
    if (!(supportPolygonForm instanceof HTMLFormElement)) return;
    if (runSupportPolygon instanceof HTMLButtonElement) runSupportPolygon.disabled = true;
    if (supportPolygonStatus) supportPolygonStatus.textContent = 'Running backend support-polygon generator...';

    try {
      const formData = new FormData(supportPolygonForm);
      const payload = Object.fromEntries(formData.entries());
      const response = await fetch('/api/support-polygon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await response.json();
      if (!response.ok || !data.ok) throw new Error(data.error || 'Support-polygon generation failed.');
      renderSupportPolygonPlot(data);
      if (supportPolygonSummary) {
        const summary = data.summary;
        supportPolygonSummary.textContent = `${summary.samples} samples, ${summary.gait_steps} gait transitions from x=${summary.x_expr}, y=${summary.y_expr}, z=${summary.z_expr}; footprint ${summary.length} m x ${summary.width} m.`;
      }
      if (supportPolygonStatus) supportPolygonStatus.textContent = 'Generated. Results are shown below.';
    } catch (error) {
      if (supportPolygonStatus) supportPolygonStatus.textContent = error instanceof Error ? error.message : String(error);
    } finally {
      if (runSupportPolygon instanceof HTMLButtonElement) runSupportPolygon.disabled = false;
    }
  }

  if (waveriderForm instanceof HTMLFormElement) {
    waveriderForm.addEventListener('input', () => {
      updateCurvePreview();
    });
    updateCurvePreview();
  }

  if (runSupportPolygon instanceof HTMLButtonElement) {
    runSupportPolygon.addEventListener('click', runSupportPolygonGenerator);
  }

  if (plotWaverider instanceof HTMLButtonElement) {
    plotWaverider.addEventListener('click', async () => {
      const payload = collectWaveriderPayload();

      plotWaverider.disabled = true;
      if (waveriderStatus) waveriderStatus.textContent = 'Running Python waverider generator...';

      try {
        const response = await fetch('/api/waverider', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Generation failed.');
        if (!data.ok) {
          if (waveriderStatus) waveriderStatus.textContent = 'Improper input.';
          if (fallbackPlot instanceof HTMLImageElement && data.images?.fallback) fallbackPlot.src = `${data.images.fallback}?t=${Date.now()}`;
          if (fallbackFigure) fallbackFigure.hidden = false;
          clearThreePlot();
          if (waveriderSummary) waveriderSummary.textContent = 'Improper input. Showing FCT, ICC, and clipped evolute curves instead.';
          if (waveriderLog) waveriderLog.textContent = [...(data.log || []), data.detail || ''].join('\n');
          if (waveriderResults) waveriderResults.hidden = false;
          return;
        }

        if (fallbackFigure) fallbackFigure.hidden = true;
        renderInteractiveGeometry(data.geometry);
        if (waveriderSummary) {
          const summary = data.summary;
          waveriderSummary.textContent = `M=${summary.mach}, beta=${summary.beta_deg} deg, span=${summary.span_m} m, ${summary.leading_edge_points} leading-edge points.`;
        }
        if (waveriderLog) {
          const logLines = [
            ...(data.log || []),
            '',
            'Interactive geometry rendered in browser.',
          ];
          waveriderLog.textContent = logLines.join('\n');
        }
        if (waveriderResults) waveriderResults.hidden = false;
        if (waveriderStatus) waveriderStatus.textContent = 'Generated. Results are shown below.';
      } catch (error) {
        if (waveriderStatus) {
          waveriderStatus.textContent = error instanceof Error ? error.message : String(error);
        }
      } finally {
        plotWaverider.disabled = false;
      }
    });
  }

  if (runInletMatlab instanceof HTMLButtonElement) {
    runInletMatlab.addEventListener('click', async () => {
      runInletMatlab.disabled = true;
      if (inletMatlabStatus) inletMatlabStatus.textContent = 'Running MATLAB inlet script...';
      try {
        const formData = inletForm instanceof HTMLFormElement ? new FormData(inletForm) : new FormData();
        const payload = Object.fromEntries([...formData.entries()].map(([key, value]) => [key, Number(value)]));
        const response = await fetch('/api/inlet-matlab', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data.error || 'MATLAB run failed.');
        if (inletMatlabPlot instanceof HTMLImageElement) inletMatlabPlot.src = `${data.image}?t=${Date.now()}`;
        if (inletMatlabFigure) inletMatlabFigure.hidden = false;
        if (inletMatlabStatus) {
          inletMatlabStatus.textContent = `Inlet plots refreshed. ${data.summary.valid} valid cases, target throat ${data.summary.target_throat.toFixed(4)} m.`;
        }
      } catch (error) {
        if (inletMatlabStatus) inletMatlabStatus.textContent = error instanceof Error ? error.message : String(error);
      } finally {
        runInletMatlab.disabled = false;
      }
    });
  }
</script>
