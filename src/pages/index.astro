---
import Layout from '../layouts/Layout.astro';

type Project = {
  id: string;
  title: string;
  oneLiner: string;
  tags: string[];
  image: string | null;
  role: string;
  problem: string;
  method: string;
  results: string;
  implemented: boolean;
  links: { label: string; url: string }[];
};

const projects = [
  {
    id: 'support-polygon',
    title: 'Support-Polygon Quadruped Gait Planner',
    oneLiner: 'Nonlinear MPC and geometry-based gait scheduler using support-polygon stability margins.',
    tags: ['C++', 'MPC', 'SQP', 'Robotics'],
    image: null,
    role: 'Sole developer (controls and gait planning).',
    problem: 'Quadruped locomotion requires coordinating leg lifts and body pose to maintain stability while tracking a desired path.',
    method: 'Formulated nonlinear MPC as a 15-state direct-shooting SQP with support-polygon area, attitude tracking, and L2 smoothing objectives. Developed a second-pass geometric heuristic selecting the next leg to lift by maximizing body-centroid stability margin within the resulting 3-leg support polygon.',
    results: 'Sub-10 s solve times. Geometric heuristic provided a tractable alternative to whole-body control for stable gait scheduling.',
    implemented: true,
    links: [],
  },
  {
    id: 'lunar-rover',
    title: 'Lunar Rover Autonomy',
    oneLiner: 'C++/ROS2 autonomy stack with D* Lite replanning, lidar obstacle updates, and spline trajectory tracking.',
    tags: ['C++', 'ROS2', 'D* Lite', 'EKF', 'Linux'],
    image: null,
    role: 'GNC & Flight Software Engineer, capstone team of 20 (Intuitive Machines / New Ascent partnership).',
    problem: 'Building a flight-software-realistic autonomy stack for a lunar micro-rover demonstrated live at the 2026 UMD Capstone Expo.',
    method: 'Co-derived continuous-time MEKF and translational EKF in C++/MATLAB; integrated TRIAD with IMU gravity and sun-vector measurements. Designed sliding mode controller validated across 400K+ Monte Carlo runs. Architected C++/ROS2 autonomy stack with D* Lite replanning and spline trajectory tracking on Linux.',
    results: '~5 deg max attitude error, ~1 cm position tracking. Aerospace Engineering Department Award at 2026 UMD Capstone Expo.',
    implemented: false,
    links: [],
  },
  {
    id: 'low-thrust',
    title: 'Low-Thrust Spacecraft Guidance',
    oneLiner: 'Indirect-shooting trajectory optimization with Kustaanheimo-Stiefel regularization for fuel-optimal asteroid rendezvous.',
    tags: ['MATLAB', 'Astrodynamics', 'Trajectory Optimization'],
    image: null,
    role: 'Research engineer, UMD Space Power and Propulsion Lab (2024-2026).',
    problem: 'Indirect methods for low-thrust trajectory optimization suffer from adjoint dynamics instability and poor numerical conditioning, limiting practical use.',
    method: 'Developed indirect low-thrust framework from scratch in MATLAB. Diagnosed adjoint dynamics instability and implemented a stabilizing approximation. Formulated Kustaanheimo-Stiefel regularized dynamics for fuel-optimal indirect shooting and built a mission design pipeline integrating NASA Horizons ephemeris and a Lambert solver.',
    results: '5x reduction in solve time, 3-5x faster convergence across 20+ tested scenarios. Published in AIAA Regional Student Conference 2026.',
    implemented: false,
    links: [],
  },
  {
    id: 'hypersonic',
    title: 'Hypersonic Inlet Optimization',
    oneLiner: 'Pattern-search scramjet inlet optimization with shock geometry and throat-gap constraints.',
    tags: ['MATLAB', 'Pattern Search', 'Hypersonics'],
    image: null,
    role: 'Controls engineer, UCAH Hypersonic Missile Team (Boeing-affiliated).',
    problem: 'Scramjet inlet design requires solving multi-ramp geometric optimization while maintaining shock-on-lip behavior, feasible ramp intersections, and a target throat height.',
    method: 'Built a MATLAB sweep that fixes freestream conditions, searches the first shock angle, optimizes downstream shock angles with patternsearch, rejects invalid geometries, and exports the solved sweep for web visualization.',
    results: 'Produced ranked candidate geometries by total pressure recovery and closest target throat gap, with ramp lengths, ramp angles, and shock miss distance available for follow-on CAD and CFD work.',
    implemented: true,
    links: [],
  },
  {
    id: 'nist',
    title: 'Microfluidic Experimental Platform',
    oneLiner: 'Coaxial-flow nanoparticle synthesis testbed with Poiseuille-tuned pneumatic pressure regulation.',
    tags: ['Experimental', 'Fluid Mechanics', 'Instrumentation'],
    image: null,
    role: 'Research engineer at NIST, U.S. Department of Commerce (summer 2025).',
    problem: "Synthesizing monodisperse nanoparticles requires precise pressure regulation in a microfluidic system whose dynamics fall outside the pump actuator's effective bandwidth.",
    method: "Designed and fabricated a coaxial microfluidic testbed. Used Poiseuille's equation to size tubing length, placing plant dynamics within pump actuator bandwidth. Characterized particles with in-line Dynamic Light Scattering and UV-Vis spectroscopy.",
    results: 'Monodisperse sub-150 nm particles with <10 nm size variance; pressure regulation within 1% of setpoint. Contributed to manuscript in preparation for Soft Matter.',
    implemented: false,
    links: [],
  },
] satisfies Project[];

const supportPolygonCodeSections = [
  {
    title: '1. Generate the Demo Trajectory',
    explanation: 'The Python plotter builds a closed 3D path, then sends that trajectory into the C++ generator. The webpage render uses this same curve shape.',
    code: `def trajectory3d(steps: int):
    t = np.linspace(0, 1, steps)
    x = np.sin(2 * np.pi * t)
    y = np.cos(2 * np.pi * t)
    z = np.cos(2 * np.pi * t)

    G = np.empty((steps, 3))
    G[:, 0] = x
    G[:, 1] = y
    G[:, 2] = z
    return G`,
  },
  {
    title: '2. Seed Quad Corner Positions',
    explanation: 'The generator initializes the four support corners from robot length and width, then rotates and translates them along the desired body trajectory.',
    code: `corners.row(0) = Eigen::Vector3d(+length / 2, -width / 2, z).transpose();
corners.row(1) = Eigen::Vector3d(+length / 2, +width / 2, z).transpose();
corners.row(2) = Eigen::Vector3d(-length / 2, +width / 2, z).transpose();
corners.row(3) = Eigen::Vector3d(-length / 2, -width / 2, z).transpose();

for (size_t k = 0; k < steps; k++) {
    Eigen::Vector3d ok = k * slope + o0;
    Eigen::RowVector3d pos_k = trajectory.row(k);
    Eigen::Matrix3d Rk = RBI(ok[0], ok[1], ok[2]);

    Stance corners_k = (corners * Rk.transpose()).rowwise() + pos_k;
    x0.col(k).segment(0, 12) = corners_k.transpose().reshaped(1, 12).transpose();
    x0.col(k).segment(12, 3) = ok;
}`,
  },
  {
    title: '3. Optimize Support Geometry',
    explanation: 'The nonlinear cost keeps the support area near the nominal footprint, follows the body path, and smooths both corner motion and orientation.',
    code: `Eigen::Vector3d ccentroid = mean(ccorners);
Eigen::Vector3d ncentroid = mean(ncorners);

Eigen::Vector3d pos_k = trajectory.row(k);
J[0] += weights.w_tracking * (ccentroid - pos_k).squaredNorm();

double A = area3d<4>(ccorners);
J[0] += weights.w_area * std::pow(A - A0, 2);
J[0] += weights.w_area_smoothness * (ncmapped - cmapped).rowwise().squaredNorm().sum();

Eigen::Vector3d r_vec = ncentroid - ccentroid;
Eigen::Vector3d r_vec_desired = trajectory.row(k + 1) - pos_k;
J[0] += weights.w_trajectory * (r_vec - r_vec_desired).squaredNorm();`,
  },
  {
    title: '4. Schedule the Next Leg',
    explanation: 'The scheduler tests each leg advancement, scores it by centroid distance and step target distance, then advances the best candidate order.',
    code: `for (int i = 0; i < 4; ++i) {
    Eigen::Vector<size_t, 4> trial = curr;
    trial[i] += 1;

    auto fposfull = get_position_at(trial);
    Eigen::Vector3d fpos = fposfull.row(i);
    double rawP = priority(curr_pos, i, cntr, fposfull, fpos);

    double biased = std::log10(std::abs(rawP)) - static_cast<double>(curr[i]) + minimum;
    priorities[i] = biased;
}

int best = std::max_element(priorities, priorities + 4) - priorities;
curr[best] += 1;`,
  },
  {
    title: '5. Render Polygons and Body Axes',
    explanation: 'The original plotter draws the trajectory, support polygon patches, and body-frame axes. The webpage implements this same visualization in Three.js.',
    code: `for k in range(0, steps, 2):
    pts = pp[k, :].reshape(4, 3)

    poly = Poly3DCollection(
        [pts],
        alpha=0.75,
        edgecolor='k',
        linewidth=1,
        facecolors=colors[int(k / 2) % 10],
    )
    ax.add_collection3d(poly)

    R = orientation(pts)
    p = np.mean(pts, axis=0)
    ax.quiver(p[0], p[1], p[2], qscale * R[0, 0], qscale * R[1, 0], qscale * R[2, 0], color='r')
    ax.quiver(p[0], p[1], p[2], qscale * R[0, 1], qscale * R[1, 1], qscale * R[2, 1], color='g')
    ax.quiver(p[0], p[1], p[2], qscale * R[0, 2], qscale * R[1, 2], qscale * R[2, 2], color='b')`,
  },
];

const cmaCodeSections = [
  {
    title: '1. Seed the ICC Control Points',
    explanation: 'CMA-ES starts from the current ICC curve rather than a generic shape. The optimizer only moves the interior points, while the endpoints stay anchored to preserve the inlet-capture boundary.',
    code: `icc_points = sample_curve(icc_curve, nsamples)
x0 = icc_points[1:-1].reshape(-1)
sigma0 = 0.03

optimizer = cma.CMAEvolutionStrategy(
    x0,
    sigma0,
    {'bounds': [lower_bounds, upper_bounds], 'popsize': 32}
)`,
  },
  {
    title: '2. Penalize Bad Evolutes',
    explanation: 'The objective rewards an ICC that remains injective when projected through the waverider construction. Folded or self-overlapping evolute behavior is penalized before the geometry reaches the 3D plotter.',
    code: `def objective(x):
    control_points = rebuild_icc(x, fixed_endpoints)
    waverider.icc_curve.set_points(control_points)

    fct_projection = project_fct_to_icc(waverider)
    injectivity = evolute_dot_loss(control_points, fct_projection)
    smoothness = curvature_loss(control_points)
    spacing = point_spacing_loss(control_points)

    return injectivity + 0.2 * smoothness + 0.1 * spacing`,
  },
  {
    title: '3. Compute the Injectivity Metric',
    explanation: 'The metric compares local tangent direction changes along the ICC/FCT relationship. Large negative dot products indicate a reversal, which is the warning sign for an evolute fold.',
    code: `def evolute_dot_loss(icc_points, fct_points):
    icc_tangent = np.diff(icc_points, axis=0)
    fct_tangent = np.diff(fct_points, axis=0)

    icc_unit = normalize_rows(icc_tangent)
    fct_unit = normalize_rows(fct_tangent)
    dots = np.sum(icc_unit * fct_unit, axis=1)

    return np.sum(np.clip(-dots, 0.0, None) ** 2)`,
  },
  {
    title: '4. Rescale and Recenter the Result',
    explanation: 'After CMA-ES finishes, the final ICC is centered and scaled back onto the FCT/ICC plotting frame. The webpage plots this corrected after-curve, then passes those control points into the 3D generator.',
    code: `best_points = rebuild_icc(result.xbest, fixed_endpoints)
best_points = optimizer.rescale_and_recenter(
    best_points,
    reference_curve=fct_points,
    preserve_endpoints=True
)

return {
    'final_control_points': best_points.tolist(),
    'best_loss': result.fbest,
}`,
  },
];

const inletCodeSections = [
  {
    title: '1. Define the Design Space',
    explanation: 'The script fixes the freestream conditions and cowl height, then sweeps cowl length and the first shock angle. This gives the optimizer a compact grid of physically meaningful starting points.',
    code: `M0      = 4.0;
gamma   = 1.4;
N_ramps = 3;

Yc = 0.28 + 0.05;              % Fixed cowl height [m]
Target_Intake_Height = 0.05;   % Desired throat gap [m]

num_Xc = 1;
Xc_min = 0.5;
Xc_max = 1.3;

num_beta1 = 50;
beta1_min_deg = rad2deg(asin(1/M0)) + 0.1;
beta1_max_deg = 40;`,
  },
  {
    title: '2. Build the Sweep Grid',
    explanation: 'The candidate cowl lengths and initial shock angles are flattened into a job list. That shape is friendly to parfor, so the same setup can scale from a quick run to a denser design sweep.',
    code: `Xc_tests = linspace(Xc_min, Xc_max, num_Xc);
beta1_tests = deg2rad(linspace(beta1_min_deg, beta1_max_deg, num_beta1));

[Xc_grid, b1_grid] = ndgrid(Xc_tests, beta1_tests);
Xc_flat_in = Xc_grid(:);
b1_flat_in = b1_grid(:);

num_jobs = length(Xc_flat_in);
results_cell = cell(num_jobs, 1);`,
  },
  {
    title: '3. Optimize the Internal Shock Train',
    explanation: 'For each first-shock candidate, patternsearch chooses the remaining shock angles. Bounds enforce a valid inlet: shocks must stay downstream, below the cowl, and above each local Mach angle.',
    code: `cost_func = @(betas) objective_wrapper( ...
    b1, betas, M0, Xc_current, Yc, gamma, N_ramps);

[optim_betas, fval, exitflag] = patternsearch( ...
    cost_func, x0, A, b_vec, [], [], lb, ub, [], ps_opts);

if fval < 0 && exitflag > 0
    [~, sol] = calc_ramp_physics( ...
        b1, optim_betas, M0, Xc_current, Yc, gamma, N_ramps);
    sol.Throat = Yc - sol.ys(end);
    results_cell{k} = sol;
end`,
  },
  {
    title: '4. Score Pressure Recovery',
    explanation: 'The physics model chains oblique shocks, computes total pressure recovery across each ramp, then applies a terminal normal shock at the throat. Invalid geometries return early and never enter the final dataset.',
    code: `function [tpr_final, s] = calc_ramp_physics(b1, betas, M0, Xc, Yc, gamma, N)
    [~, M2, tpr1] = oblique(M0, b1, gamma);
    s.Machs(2) = M2;
    s.tprs(1) = tpr1;

    for ramp = 2:N
        b_rel = b_abs - theta_abs_prev;
        mu = asin(1 / s.Machs(ramp));
        if b_rel <= mu || b_rel >= pi/2
            return;
        end
        [~, M_next, tpr] = oblique(s.Machs(ramp), b_rel, gamma);
        s.tprs(ramp) = tpr;
    end

    [~, ~, tpr_normal] = oblique(M_throat, pi/2, gamma);
    s.TPR = prod(s.tprs) * tpr_normal;
    tpr_final = s.TPR;
end`,
  },
  {
    title: '5. Export Portfolio Data',
    explanation: 'The web export stores only the clean sweep points and selected solutions. That keeps the browser focused on storytelling while MATLAB remains the source of truth for the numerical solve.',
    code: `web_export = struct();
web_export.inputs = struct( ...
    'M0', M0, ...
    'gamma', gamma, ...
    'N_ramps', N_ramps, ...
    'target_throat_m', Target_Intake_Height);

web_export.points = web_points;
web_export.best_tpr_solution = best_tpr_sol;
web_export.target_solution = target_sol;

fid = fopen('ucah_sweep_results.json', 'w');
fwrite(fid, jsonencode(web_export), 'char');
fclose(fid);`,
  },
];
---
<Layout>
  <main class="max-w-2xl mx-auto px-5 py-12">
    <header class="border-b border-stone-200 pb-8 mb-10">
      <h1 class="text-3xl font-semibold tracking-tight">Srikrishnan Sridhar</h1>
      <p class="mt-1 text-stone-600">Spacecraft & Robotic Autonomy</p>
      <p class="mt-4 text-stone-700 leading-relaxed text-[15px]">
        I build guidance, estimation, planning, and control systems for autonomous aerospace and robotic platforms. B.S. Aerospace Engineering & Applied Mathematics, University of Maryland (2026). Incoming graduate student, Johns Hopkins Robotics.
      </p>
      <div class="mt-4 flex gap-4 text-sm text-stone-600">
        <a href="mailto:skrish18@terpmail.umd.edu" class="hover:text-stone-900 underline-offset-2 hover:underline">Email</a>
        <a href="https://linkedin.com/in/srikrishnansridhar" class="hover:text-stone-900 underline-offset-2 hover:underline">LinkedIn</a>
        <a href="https://github.com/KrishTheDuck" class="hover:text-stone-900 underline-offset-2 hover:underline">GitHub</a>
      </div>
    </header>

    <section>
      <h2 class="text-xs uppercase tracking-wider text-stone-500 mb-4">Selected Work</h2>
      <div class="space-y-3">
        {projects.map((p) => (
          <button
            data-modal-id={p.id}
            class={`project-trigger w-full text-left flex gap-4 p-4 border rounded transition-colors ${p.implemented ? 'border-stone-300 bg-white hover:border-stone-500' : 'draft-project border-stone-200 bg-stone-100/60 hover:border-stone-300 hover:bg-stone-100'}`}
          >
            <div class={`flex-shrink-0 w-20 h-20 border rounded flex items-center justify-center overflow-hidden ${p.implemented ? 'bg-stone-100 border-stone-200' : 'bg-stone-200 border-stone-300'}`}>
              {p.image ? (
                <img src={p.image} alt={p.title} class="w-full h-full object-cover" />
              ) : (
                <span class="text-[10px] text-stone-400 text-center px-1 leading-tight">{p.title.split(' ').slice(0, 3).join(' ')}</span>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-medium text-stone-900">{p.title}</h3>
              <p class="mt-1 text-sm text-stone-600 leading-snug">{p.oneLiner}</p>
              <div class="mt-2 flex flex-wrap gap-1.5">
                {p.tags.map((tag) => (
                  <span class="text-[11px] px-1.5 py-0.5 bg-stone-100 text-stone-600 rounded">{tag}</span>
                ))}
              </div>
            </div>
          </button>
        ))}
      </div>
    </section>

    <footer class="mt-16 pt-8 border-t border-stone-200 text-sm text-stone-500">
      <p>© 2026 Srikrishnan Sridhar · College Park, MD</p>
    </footer>
  </main>

  {projects.map((p) => (
    <dialog id={`modal-${p.id}`} class="project-modal">
      <div class="modal-content">
        <div class="flex items-start justify-between mb-4">
          <h2 class="text-xl font-semibold pr-8">{p.title}</h2>
          <button class="close-modal text-stone-400 hover:text-stone-900 text-2xl leading-none" aria-label="Close">×</button>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-6">
          {p.tags.map((tag) => (
            <span class="text-[11px] px-1.5 py-0.5 bg-stone-100 text-stone-600 rounded">{tag}</span>
          ))}
        </div>

        {p.id === 'support-polygon' && (
          <div class="space-y-6 mb-7">
            <section class="support-hero">
              <video controls muted loop playsinline preload="metadata">
                <source src="/testudog-support-polygon.webm" type="video/webm" />
              </video>
              <p>Support-polygon gait planning demo from the Testudog stack. The planner uses stance-foot geometry to decide which leg can safely swing next while preserving body stability.</p>
            </section>

            <section class="support-plot-panel">
              <div>
                <h3>Live Support-Polygon Generator</h3>
                <p>Enter trajectory functions of t, sample the backend generator, and render the returned support polygons in the browser.</p>
              </div>
              <form id="support-polygon-form" class="support-form">
                <label><span>x(t)</span><input name="x_expr" value="sin(2*pi*t)" /></label>
                <label><span>y(t)</span><input name="y_expr" value="cos(2*pi*t)" /></label>
                <label><span>z(t)</span><input name="z_expr" value="0.55*cos(2*pi*t)" /></label>
                <label><span>Samples</span><input name="samples" type="number" min="4" max="160" step="1" value="30" /></label>
                <label><span>Length</span><input name="length" type="number" min="0.02" step="0.01" value="0.34" /></label>
                <label><span>Width</span><input name="width" type="number" min="0.02" step="0.01" value="0.18" /></label>
                <button type="button" id="run-support-polygon" class="primary-action">Generate</button>
              </form>
              <div id="support-polygon-status" class="waverider-status">Ready.</div>
              <div class="interactive-plot-shell">
                <div id="support-polygon-plot" class="interactive-plot"></div>
                <div class="plot-legend" aria-label="Support polygon legend">
                  <span class="legend-trajectory">Trajectory</span>
                  <span class="legend-support">Support polygon</span>
                  <span class="legend-xaxis">Body X</span>
                  <span class="legend-yaxis">Body Y</span>
                  <span class="legend-zaxis">Body Z</span>
                  <span class="legend-gait">Animated gait</span>
                </div>
                <p id="support-polygon-summary">Support polygons rendered from backend trajectory samples.</p>
              </div>
            </section>

            <section class="support-grid">
              <article>
                <h3>Geometry Layer</h3>
                <p>Transforms active foot contacts into a convex support polygon and measures body-center margin against each edge.</p>
              </article>
              <article>
                <h3>Gait Scheduler</h3>
                <p>Simulates each possible leg lift and chooses the swing leg that leaves the largest remaining support margin.</p>
              </article>
              <article>
                <h3>MPC Interface</h3>
                <p>Packages the swing-leg decision into a trajectory command for pose tracking, contact timing, and smoothing costs.</p>
              </article>
            </section>

            <div class="code-walkthrough">
              <div class="code-intro">
                <h3>Support-Polygon Gait Planner Code</h3>
                <p>The snippets below capture the planner structure: contact filtering, convex-hull construction, signed stability margin, swing-leg selection, and MPC handoff.</p>
              </div>
              {supportPolygonCodeSections.map((section) => (
                <section class="code-section">
                  <h3>{section.title}</h3>
                  <p>{section.explanation}</p>
                  <pre><code>{section.code}</code></pre>
                </section>
              ))}
            </div>
          </div>
        )}

        {p.id === 'hypersonic' && (
          <div class="space-y-6 mb-7">
            <section class="waverider-panel">
              <div class="waverider-panel-header">
                <div>
                  <h3>Run Waverider Generator</h3>
                  <p>Adjust the input deck, generate the geometry, and rotate the returned 3D plot directly here.</p>
                </div>
                <button type="button" id="plot-waverider" class="primary-action">Plot 3D</button>
              </div>

              <div class="waverider-workbench">
                <form id="waverider-form" class="waverider-form">
                  <label>
                    <span>Mach</span>
                    <input name="mach" type="number" step="0.1" value="4" />
                  </label>
                  <label>
                    <span>Gamma</span>
                    <input name="gamma" type="number" step="0.01" value="1.4" />
                  </label>
                  <label>
                    <span>Shock beta</span>
                    <input name="beta" type="number" step="0.5" value="20" />
                  </label>
                  <label>
                    <span>Seed points</span>
                    <input name="seed_num" type="number" step="2" value="101" />
                  </label>
                  <label>
                    <span>Ghost points</span>
                    <input name="nghost" type="number" step="1" value="5" />
                  </label>
                  <label>
                    <span>Span</span>
                    <input name="span" type="number" step="0.05" value="0.5" />
                  </label>
                <label>
                  <span>CMA ctrl pts</span>
                  <input name="nsamples" type="number" step="1" value="9" />
                </label>
                  <label>
                    <span>FCT type</span>
                    <select name="fct_type">
                      <option selected>Cosine</option>
                      <option>Power</option>
                      <option>Absolute Value</option>
                      <option>Circle</option>
                    </select>
                  </label>
                  <label class="wide">
                    <span>FCT a,b,c,d,n</span>
                    <input name="fct_abcdn" value="-0.1,4,0,-0.11,1" />
                  </label>
                  <label>
                    <span>ICC type</span>
                    <select name="icc_type">
                      <option selected>Cosine</option>
                      <option>Power</option>
                      <option>Absolute Value</option>
                      <option>Circle</option>
                    </select>
                  </label>
                  <label class="wide">
                    <span>ICC a,b,c,d,n</span>
                    <input name="icc_abcdn" value="0.01,4,0,0,1" />
                  </label>
                </form>

                <aside class="equation-preview">
                  <div class="equation-row">
                    <span>FCT</span>
                    <code id="fct-equation"></code>
                  </div>
                  <div class="equation-row">
                    <span>ICC</span>
                    <code id="icc-equation"></code>
                  </div>
                  <svg id="curve-preview" viewBox="0 0 360 220" role="img" aria-label="Live FCT and ICC curve preview">
                    <rect x="0" y="0" width="360" height="220" rx="8"></rect>
                    <path id="fct-preview-path"></path>
                    <path id="icc-preview-path"></path>
                    <line x1="24" y1="196" x2="336" y2="196"></line>
                    <line x1="180" y1="24" x2="180" y2="196"></line>
