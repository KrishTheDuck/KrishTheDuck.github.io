---
interface Props {
  title: string;
  oneLiner: string;
  tags: string[];
  href?: string;
}
const { title, oneLiner, tags, href } = Astro.props;
---
{href ? (
  <a href={href} class="block p-6 border border-gray-200 rounded-lg hover:border-gray-400 hover:shadow-sm transition">
    <h3 class="text-lg font-semibold">{title}</h3>
    <p class="mt-1 text-sm text-gray-600">{oneLiner}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map(tag => <span class="text-xs px-2 py-1 bg-gray-100 text-gray-700 rounded">{tag}</span>)}
    </div>
  </a>
) : (
  <div class="block p-6 border border-gray-200 rounded-lg">
    <h3 class="text-lg font-semibold">{title}</h3>
    <p class="mt-1 text-sm text-gray-600">{oneLiner}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map(tag => <span class="text-xs px-2 py-1 bg-gray-100 text-gray-700 rounded">{tag}</span>)}
    </div>
  </div>
)}